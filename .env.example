APP_HOST=localhost
ASPNETCORE_ENVIRONMENT=Development

POSTGRES_DB=wordle_trackersupreme
POSTGRES_USER=wordle_user
POSTGRES_PASSWORD=please-change-me

JWT_SECRET=replace-with-at-least-32-characters

# Optional comma-delimited guidance only; actual binding is controlled by the backend config source.
# Keep localhost entries aligned with the frontend dev and compose ports when overriding CORS.
# Cors__AllowedOrigins__0=http://localhost:3000
# Cors__AllowedOrigins__1=http://127.0.0.1:3000

# Only needed when enabling the Traefik ACME lines in docker-compose.yml.
# TRAEFIK_ACME_EMAIL=you@example.com
